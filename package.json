{
  "name": "@racehooks/f1-fantasy-scorer",
  "version": "0.1.0",
  "description": "Live F1 Fantasy point scoring from RaceHooks, the motorsports analytics platform — official F1 Fantasy and DFS rule sets, constructor aggregation, roster optimizer, fully typed.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build && npm test",
    "release": "semantic-release"
  },
  "keywords": [
    "formula1",
    "f1",
    "fantasy",
    "fantasy-f1",
    "scoring",
    "dfs",
    "racing",
    "racehooks",
    "webhooks",
    "typescript"
  ],
  "license": "MIT",
  "homepage": "https://racehooks.io",
  "bugs": {
    "url": "https://github.com/racehooks/f1-fantasy-scorer/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/racehooks/f1-fantasy-scorer.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.19",
    "jest": "^29.7.0",
    "semantic-release": "^25.0.7",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  }
}
